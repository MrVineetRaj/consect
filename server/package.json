    "db:studio": "pnpm exec drizzle-kit studio",
    "db:push": "pnpm exec drizzle-kit push",
    "db:seed": "tsx src/app/db/seed.ts",
    "auth:generate": "pnpm exec auth@latest generate --config src/app/lib/auth.ts"
  },
